# ============================================================
# Robot AI Assistant - Konfiguracja
# ============================================================

# ----------------------------
# Wybór klienta AI
# Opcje: anthropic | openai | groq | ollama
# ----------------------------
AI_PROVIDER=anthropic

# ----------------------------
# Klucze API (uzupełnij tylko ten którego używasz)
# ----------------------------
ANTHROPIC_API_KEY=sk-ant-twoj-klucz-tutaj
OPENAI_API_KEY=sk-twoj-klucz-tutaj
GROQ_API_KEY=gsk_twoj-klucz-tutaj



# ----------------------------
# Model AI
# Anthropic: claude-opus-4-20250514 | claude-sonnet-4-20250514 | claude-haiku-4-5-20251001
# OpenAI:    gpt-4o | gpt-4o-mini | gpt-4-turbo
# Groq:      llama-3.3-70b-versatile | mixtral-8x7b-32768 | gemma2-9b-it
# Ollama:    llama3 | mistral | phi3
# ----------------------------
AI_MODEL=claude-opus-4-20250514

# ----------------------------
# Ustawienia serwera
# ----------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=5000

# ----------------------------
# TTS - jezyk odpowiedzi glosowej (pl, en, de, fr, ...)
# ----------------------------
TTS_LANG=pl

# ----------------------------
# Ollama - adres jesli nie lokalny
# ----------------------------
OLLAMA_BASE_URL=http://localhost:11434/v1
